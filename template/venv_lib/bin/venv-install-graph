#!/bin/sh

cd `dirname $0`



if [ -z "$VENV_DIR" ]; then
  echo "Error: missing VENV_DIR"
  exit 1
fi

if [ ! -d "$VENV_DIR" ]; then
  echo "Error: invalid VENV_DIR ${VENV_DIR}"
  exit 1
fi

if [ -z "$VENV_CONTAINER" ]; then
  echo "Error: missing VENV_CONTAINER"
  exit 1
fi


cd ${VENV_DIR}

npm install -g @graphprotocol/graph-cli

mkdir -p ${VENV_DIR}/.envrc.bin

cat <<_EOF > ${VENV_DIR}/.envrc.bin/graph
#!/bin/bash

VENV_CONTAINER=${VENV_CONTAINER}
EXEC_NAME=graph

exec docker exec -ti \
  -w "\$PWD" \
  \${VENV_CONTAINER} \${EXEC_NAME} "\$@"

_EOF

chmod +x ${VENV_DIR}/.envrc.bin/graph

