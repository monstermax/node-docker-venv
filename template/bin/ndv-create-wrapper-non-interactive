#!/bin/bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: ndv-create-wrapper-ni <executable_name>" >&2
  echo "  Creates .envrc.bin/<executable_name> — a wrapper that runs the binary" >&2
  echo "  inside the venv container (non-interactive mode)." >&2
  echo "  Use this for tools called by editors or CI (e.g. VSCode extensions)." >&2
  exit 1
fi

[ -z "${VENV_CONTAINER:-}" ] && echo "Error: VENV_CONTAINER is not set (is the venv active?)" >&2 && exit 1
[ -z "${VENV_DIR:-}" ]       && echo "Error: VENV_DIR is not set (is the venv active?)" >&2 && exit 1

EXEC_NAME="$1"
BIN_DIR="${VENV_DIR}/.envrc.bin"
WRAPPER="${BIN_DIR}/${EXEC_NAME}"

mkdir -p "$BIN_DIR"

cat > "$WRAPPER" << EOF
#!/bin/bash
# Wrapper generated by ndv-create-wrapper-ni
# Non-interactive mode (-i) — for editors, CI, and tools without a TTY

# VENV_CONTAINER is resolved dynamically from the environment (set by direnv).
# If you need this wrapper to work outside of direnv (e.g. called by an editor),
# uncomment and hardcode the container name below:
#VENV_CONTAINER=${VENV_CONTAINER}

exec docker exec -i \\
  -w "\$PWD" \\
  "\${VENV_CONTAINER}" "${EXEC_NAME}" "\$@"
EOF

chmod +x "$WRAPPER"

echo "Created non-interactive wrapper: $WRAPPER"
