#!/bin/bash


PROJECT_DIR=$(realpath ${1:-$PWD})


if [ -z "$PROJECT_DIR" -o ! -d "$PROJECT_DIR" ]; then
    echo "Invalid project dir"
    exit 1
fi


echo '
    dMMMMb  .aMMMb  dMMMMb  dMMMMMP         dMMMMb  .aMMMb  .aMMMb  dMP dMP dMMMMMP dMMMMb       dMP dMP dMMMMMP dMMMMb  dMP dMP 
   dMP dMP dMP"dMP dMP VMP dMP             dMP VMP dMP"dMP dMP"VMP dMP.dMP dMP     dMP.dMP      dMP dMP dMP     dMP dMP dMP dMP  
  dMP dMP dMP dMP dMP dMP dMMMP           dMP dMP dMP dMP dMP     dMMMMK" dMMMP   dMMMMK"      dMP dMP dMMMP   dMP dMP dMP dMP   
 dMP dMP dMP.aMP dMP.aMP dMP             dMP.aMP dMP.aMP dMP.aMP dMP"AMF dMP     dMP"AMF       YMvAP" dMP     dMP dMP  YMvAP"    
dMP dMP  VMMMP" dMMMMP" dMMMMMP         dMMMMP"  VMMMP"  VMMMP" dMP dMP dMMMMMP dMP dMP         VP"  dMMMMMP dMP dMP    VP"      
'


# Project name
VENV_PROJECT=$(basename $PROJECT_DIR)
echo "Project name ? (default: \"${VENV_PROJECT}\")"
read VENV_PROJECT_2

if [ "$VENV_PROJECT_2" != "" ]; then
    VENV_PROJECT="${VENV_PROJECT_2}"
fi


echo "Creating venv \"${VENV_PROJECT}\" into ${PROJECT_DIR}" 
echo "[Press Enter to continue]"
read


cp -a $HOME/.node-docker-venv/config/envrc "${PROJECT_DIR}/.envrc"


# Add VENV_PROJECT to the .envrc

TMP_FILE=$(mktemp)
(
    grep -v "source .*/venv-activate" .envrc
    #echo "export VENV_PROJECT=\$(basename \$PROJECT_DIR)"
    echo "export VENV_PROJECT=\"$VENV_PROJECT\""
    echo "source \$HOME/.node-docker-venv/venv_lib/scripts/venv-activate"
) > $TMP_FILE
#cat $TMP_FILE # debug
cat $TMP_FILE > "${PROJECT_DIR}/.envrc"
rm $TMP_FILE


#cd "$PROJECT_DIR"
#export PWD=$PROJECT_DIR
#direnv allow


exec direnv allow

