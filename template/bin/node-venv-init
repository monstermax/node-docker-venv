#!/bin/bash
set -euo pipefail

NDV_DIR="${NDV_DIR:-$HOME/.node-docker-venv}"

# ─── Load global config ───────────────────────────────────────────────────────
[ -f "$NDV_DIR/config/config" ] && source "$NDV_DIR/config/config"

DEFAULT_NODE_VERSION="${NDV_DEFAULT_NODE_VERSION:-22-alpine}"

# ─── Flags ────────────────────────────────────────────────────────────────────
YES=0       # -y : non-interactive, use defaults
RESOURCES=0 # -r : also prompt for resource limits (ignored with -y)

while getopts ":yr" opt; do
  case $opt in
    y) YES=1 ;;
    r) RESOURCES=1 ;;
    *) echo "Usage: node-venv-init [-y] [-r] [PROJECT_DIR]" >&2; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

# ─── Project directory ────────────────────────────────────────────────────────
PROJECT_DIR=$(realpath "${1:-$PWD}")

if [ ! -d "$PROJECT_DIR" ]; then
  echo "Error: directory does not exist: $PROJECT_DIR" >&2
  exit 1
fi

# ─── Banner ───────────────────────────────────────────────────────────────────
if [ "$YES" = "0" ]; then
  cat <<'BANNER'

  ┌─────────────────────────────────────────┐
  │          node-docker-venv init          │
  └─────────────────────────────────────────┘

BANNER
fi

# ─── Collect values ───────────────────────────────────────────────────────────
DEFAULT_PROJECT=$(basename "$PROJECT_DIR")

if [ "$YES" = "1" ]; then
  # Non-interactive: use all defaults
  VENV_PROJECT="$DEFAULT_PROJECT"
  VENV_NODE_VERSION="$DEFAULT_NODE_VERSION"
  VENV_MEM_LIMIT=""
  VENV_CPU_LIMIT=""
  VENV_PIDS_LIMIT=""
else
  # Project name
  echo "Project name? (default: \"$DEFAULT_PROJECT\")"
  read -r INPUT
  VENV_PROJECT="${INPUT:-$DEFAULT_PROJECT}"

  # Node version
  echo "Node version? (default: \"$DEFAULT_NODE_VERSION\")"
  echo "  Examples: 22-alpine  22-bookworm-slim  24-trixie-slim"
  read -r INPUT
  VENV_NODE_VERSION="${INPUT:-$DEFAULT_NODE_VERSION}"

  # Resource limits (only if -r)
  VENV_MEM_LIMIT=""
  VENV_CPU_LIMIT=""
  VENV_PIDS_LIMIT=""

  if [ "$RESOURCES" = "1" ]; then
    echo "Memory limit? (default: unlimited, e.g. 512m)"
    read -r INPUT
    VENV_MEM_LIMIT="${INPUT:-}"

    echo "CPU limit? (default: unlimited, e.g. 2)"
    read -r INPUT
    VENV_CPU_LIMIT="${INPUT:-}"

    echo "PIDs limit? (default: unlimited, e.g. 200)"
    read -r INPUT
    VENV_PIDS_LIMIT="${INPUT:-}"
  fi
fi

# ─── Write .envrc ─────────────────────────────────────────────────────────────
ENVRC="$PROJECT_DIR/.envrc"

{
  echo "# Generated by node-venv-init"
  echo ""
  echo "# ─── Node version ───────────────────────────────────────────────────────────"
  echo "export VENV_NODE_VERSION=\"${VENV_NODE_VERSION}\""
  echo ""
  echo "# ─── Resource limits (default: unlimited) ───────────────────────────────────"

  if [ -n "$VENV_MEM_LIMIT" ]; then
    echo "export VENV_MEM_LIMIT=${VENV_MEM_LIMIT}"
  else
    echo "#export VENV_MEM_LIMIT=512m"
  fi

  if [ -n "$VENV_CPU_LIMIT" ]; then
    echo "export VENV_CPU_LIMIT=${VENV_CPU_LIMIT}"
  else
    echo "#export VENV_CPU_LIMIT=2"
  fi

  if [ -n "$VENV_PIDS_LIMIT" ]; then
    echo "export VENV_PIDS_LIMIT=${VENV_PIDS_LIMIT}"
  else
    echo "#export VENV_PIDS_LIMIT=200"
  fi

  echo ""
  echo "# ─── Activate ───────────────────────────────────────────────────────────────"
  echo "export VENV_PROJECT=\"${VENV_PROJECT}\""
  echo 'export VENV_DIR=$(realpath $(dirname $BASH_SOURCE))'
  echo 'source $HOME/.node-docker-venv/scripts/activate'
} > "$ENVRC"

# ─── Done ─────────────────────────────────────────────────────────────────────
echo ""
echo "Created .envrc for project \"$VENV_PROJECT\" (node ${VENV_NODE_VERSION})"
echo "Activating..."
echo ""

cd "$PROJECT_DIR"
exec direnv allow
